import pandas as pd
import numpy as np

# Load the dataset from a CSV file into a DataFrame
df = pd.read_csv("trips_by_distance.csv")

# Standardize column names:
# - Convert to lowercase
# - Remove leading/trailing whitespace
df.columns = df.columns.str.lower().str.strip()

# Handle missing values:
# Fill NaN values in numeric columns with the mean of each column
df = df.fillna(df.select_dtypes(include='number').mean())

# Remove duplicate rows from the dataset
df = df.drop_duplicates()

# Display the first 5 rows of the cleaned dataset
df.head()

# Display information about the dataset:
# Includes column names, non-null counts, and data types
df.info()

# Load the original dataset again for comparison (before cleaning)
df_original = pd.read_csv("trips_by_distance.csv")

# Print the number of missing values in each column before cleaning
print("Before cleaning:", df_original.isnull().sum())

# Print the number of missing values in each column after cleaning
print("After cleaning:", df.isnull().sum())
